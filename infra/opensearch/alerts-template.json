{
  "index_patterns": ["guardian-alerts-*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.mapping.ignore_malformed": true
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "alert": {
          "properties": {
            "id":          { "type": "keyword" },
            "type":        { "type": "keyword" },
            "severity":    { "type": "keyword" },
            "source":      { "type": "keyword" },
            "entity_type": { "type": "keyword" },
            "entity_id":   { "type": "keyword" },
            "score":       { "type": "float" },
            "summary":     { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 512 } } },
            "window": {
              "properties": {
                "start": { "type": "date" },
                "end":   { "type": "date" }
              }
            }
          }
        }
      }
    }
  }
}
